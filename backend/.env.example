# ============================================================
# Alexander AI Solutions — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars

# PostgreSQL
# Set SKIP_DB=true to run without a real database (uses in-memory mock)
DATABASE_URL=postgresql://postgres:password@localhost:5432/alexander_ai
DATABASE_SSL=false
SKIP_DB=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# File uploads
UPLOAD_MAX_SIZE_MB=10
